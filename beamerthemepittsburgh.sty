%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Get centered TOC
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% 
% \newlength{\secnamelength}
% \newsavebox{\longestsec}% Box to save longest sectional heading
% \patchcmd{\beamer@section}% <cmd>
%   {\beamer@savemode}% <search>
%   {\begin{lrbox}{\longestsec}#1\end{lrbox}%
%    \ifdim\wd\longestsec>\secnamelength\relax\setlength{\secnamelength}{\wd\longestsec}\fi%
%    \beamer@savemode}% <replace>
%   {}{}% <success><failure>
% \AtEndDocument{% http://tex.stackexchange.com/q/137495/5764
%   \immediate\write\@auxout{\global\secnamelength=\the\secnamelength}%
% }
\makeatletter
\newlength{\secnamelength}
\newsavebox{\longestsec}% Box to save longest sectional heading
\patchcmd{\beamer@section}% <cmd>
{\beamer@savemode}% <search>
{
\ifstrempty{#2}{%
    % The "2. " is just so that the number in the section
    % is also counted in the calculation of the longest sec
    \begin{lrbox}{\longestsec}2. #1\end{lrbox}
    \ifthenelse{
        \wd\longestsec > \secnamelength
    }{
        \setlength{\secnamelength}{\wd\longestsec}
    }{}%else
}{
    % The "2. " is just so that the number in the section
    % is also counted in the calculation of the longest sec
    \begin{lrbox}{\longestsec}2. #2\end{lrbox}
    \ifthenelse{
        \wd\longestsec > \secnamelength
    }{
        \setlength{\secnamelength}{\wd\longestsec}
    }{}%else
}
\beamer@savemode
}% <replace>
{}{}% <success><failure>
\AtEndDocument{% http://tex.stackexchange.com/q/137495/5764
    \immediate\write\@auxout{\global\secnamelength=\the\secnamelength}%
}
\makeatother
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Initial page TOC
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% 

\newcommand{\firstpagetoc} {
\begin{frame}[noframenumbering]
 \frametitle{\toctitle{}}
 \setlength{\leftskip}{\dimexpr.5\textwidth-.5\secnamelength\relax}% Advance left margin accordingly
 \tableofcontents
 
 % \setlength{\leftskip}{\dimexpr.5\textwidth-.5\secnamelength\relax}
 % \tableofcontents
 \thispagestyle{empty}
\end{frame}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% TOC highlighting at beginning
% of each section
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% 

\AtBeginSection{
  \ifnum\includetoc=1{%
      \begin{frame}[noframenumbering]
        \frametitle{\toctitle{}}
        \setlength{\leftskip}{\dimexpr.5\textwidth-.5\secnamelength\relax}% Advance left margin accordingly
        {\bfseries \tableofcontents[currentsection]}
        % Setting bfseries here to only bold the upcoming section.
        % Somehow, it doesn't apply to the shaded stuff because I set it to \mdseries above.
        % Not sure why it works, but it does!
        \thispagestyle{empty}
      \end{frame}
    }
  \fi
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Widen command
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% 
\newcommand\widen[2][3em]{%
\makebox[\linewidth][c]{%
  \begin{minipage}{\dimexpr\textwidth+#1\relax}
  \raggedright#2
  \end{minipage}%
  }%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Centered Slide numbers
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% 
\defbeamertemplate{footline}{centered plain}{%
  \begin{beamercolorbox}[wd=\textwidth, sep=3ex]{footline}%
  \centering
    \usebeamerfont{page number in head/foot}%
    \usebeamertemplate*{frame footer}
    \usebeamertemplate*{frame numbering}
  \end{beamercolorbox}%
}

\setbeamertemplate{footline}[centered plain]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Collaborators slide
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% 

\newcommand{\displayimages}[5]{
  \centering
  \foreach \filename/\collabname in #2 {
    % Dynamically create minipage size based on number of collaborators
    \begin{minipage}{#3\textwidth}
    % \begin{minipage}{0.45\textwidth}
      \centering
      \includegraphics[height=#4\textheight]{#1\filename}\\
      {#5 \collabname}

    \end{minipage}
  }
}
