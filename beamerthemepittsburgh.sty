% Define a command to check if the frame has a title
\makeatletter
\newcommand{\ifframetitle}[2]{%
  \ifx\insertframetitle\@empty
    #1%
  \else
    #2%
  \fi
}
\makeatother

% Define the desired vspace for frames with and without titles
\newcommand{\frametitlespace}{\ifframetitle{\vspace{1cm}}{\vspace{0cm}}}

\setbeamertemplate{frametitle}{%
    \nointerlineskip%

    \begin{beamercolorbox}[wd=\paperwidth,ht=4.0ex,dp=0.6ex]{frametitle}
      \centering\insertframetitle%
    \end{beamercolorbox}%
    \frametitlespace
}

